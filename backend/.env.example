NODE_ENV=development
HOST=0.0.0.0
PORT=3000
FRONTEND_PORT=3001
FRONTEND_BUILD_ON_START=true
FRONTEND_DIST_PATH=frontend/dist

# JWT
JWT_SECRET=replace-with-a-64-byte-hex-secret

# Auth
AUTH_MODE=ldap

# Database (PostgreSQL only)
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nebula_proxy
DB_USER=nebula
DB_PASSWORD=change-me


# LDAP
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin
LDAP_ADMIN_GROUP=CN=ProxyAdmins,OU=Groups,DC=example,DC=com
LDAP_USER_GROUP=CN=ProxyUsers,OU=Groups,DC=example,DC=com
LDAP_REQUIRE_GROUP=false

# Proxy + security
PROXY_ENABLED=true
PROXY_CHECK_TOKEN=replace-with-a-random-token
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
ALLOW_PRIVATE_BACKENDS=false
ALLOW_INSECURE_BACKENDS=false
HTTP_PROXY_REQUEST_TIMEOUT_MS=30000

# Tunnels
TUNNEL_PUBLIC_DOMAIN=tunnel.nebula-app.dev
TUNNEL_PORT_RANGE_MIN=20000
TUNNEL_PORT_RANGE_MAX=29999
TUNNEL_ENROLLMENT_CODE_TTL_MINUTES=15

# Proxy 502 error page
BAD_GATEWAY_HTML_TITLE=Bad Gateway
BAD_GATEWAY_BADGE=Bad Gateway
BAD_GATEWAY_TITLE=Service amont indisponible
BAD_GATEWAY_SUBTITLE=Le proxy ne peut pas joindre le backend pour ce domaine. L'ecran suit le meme theme que l'interface admin afin de garder une experience coherente.
BAD_GATEWAY_MESSAGE=The backend server is temporarily unavailable
BAD_GATEWAY_DOMAIN_LABEL=Domaine
BAD_GATEWAY_PROXY_LABEL=Proxy
BAD_GATEWAY_PROXY_VALUE=NebulaProxy
BAD_GATEWAY_CAUSE_LABEL=Cause
BAD_GATEWAY_CAUSE_VALUE=Backend not reachable
BAD_GATEWAY_STATUS_LABEL=Statut
BAD_GATEWAY_STATUS_VALUE=502 Service Unavailable
BAD_GATEWAY_RETRY_BUTTON=Reessayer
BAD_GATEWAY_BACK_BUTTON=Retour
BAD_GATEWAY_FOOTER_TEXT=Contactez l'administrateur si le probleme persiste.

# Health checks
HEALTHCHECK_INTERVAL_SECONDS=5
HEALTHCHECK_CONCURRENCY=10
HEALTHCHECK_TIMEOUT_MS=10000
HEALTHCHECK_CLEANUP_EVERY=100

# Logs
LOG_RETENTION_DAYS=30
LOG_CLEANUP_INTERVAL_HOURS=24

# Live traffic retention (Redis)
LIVE_TRAFFIC_RETENTION_DAYS=30
LIVE_TRAFFIC_CLEANUP_INTERVAL_MS=3600000

# SMTP Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_FROM_NAME=NebulaProxy
SMTP_FROM_EMAIL=

# SMTP Proxy Relay
SMTP_PROXY_ENABLED=false
SMTP_PROXY_BIND_ADDRESS=0.0.0.0
SMTP_PROXY_BACKEND_HOST=mail.example.com
SMTP_PROXY_BACKEND_PORT=25
SMTP_PROXY_PORT=25
SMTP_PROXY_SUBMISSION_PORT=587
SMTP_PROXY_SMTPS_PORT=465
SMTP_PROXY_IDLE_TIMEOUT_MS=300000
SMTP_PROXY_CONNECT_TIMEOUT_MS=10000
SMTP_PROXY_LOGGING_ENABLED=true

# ACME / Let's Encrypt
ACME_EMAIL=admin@example.com

# Frontend
VITE_API_BASE_URL=/api
ALLOW_INSECURE_BACKENDS=true
