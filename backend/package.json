{
  "name": "nebula-proxy-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "smtp:test": "node scripts/test-smtp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:backup": "pg_dump -h localhost -U nebula nebula_proxy > backup-$(date +%Y%m%d-%H%M%S).sql",
    "config:show": "node scripts/config-manager.js show",
    "config:edit": "node scripts/config-manager.js edit",
    "config:reset": "node scripts/config-manager.js reset",
    "config:export": "node scripts/config-manager.js export",
    "config:import": "node scripts/config-manager.js import",
    "admin:reset-password": "node scripts/reset-admin-password.js",
    "admin:disable-2fa": "node scripts/disable-user-2fa.js",
    "tunnel:agent": "node scripts/tunnel-agent.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/lib-storage": "^3.1004.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/http-proxy": "^9.5.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@simplewebauthn/server": "^13.2.2",
    "cron": "^4.4.0",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.8.2",
    "ldapjs": "^3.0.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.16.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "selfsigned": "^5.2.0",
    "uuid": "^13.0.0",
    "validator": "^13.15.26",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "vitest": "^2.1.8"
  }
}
