NODE_ENV=development
HOST=0.0.0.0
PORT=3000
FRONTEND_PORT=3001
FRONTEND_BUILD_ON_START=true
FRONTEND_DIST_PATH=frontend/dist

# JWT
JWT_SECRET=replace-with-a-64-byte-hex-secret

# Auth
AUTH_MODE=ldap

# Database (PostgreSQL only)
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nebula_proxy
DB_USER=nebula
DB_PASSWORD=change-me


# LDAP
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin
LDAP_ADMIN_GROUP=CN=ProxyAdmins,OU=Groups,DC=example,DC=com
LDAP_USER_GROUP=CN=ProxyUsers,OU=Groups,DC=example,DC=com
LDAP_REQUIRE_GROUP=false

# Proxy + security
PROXY_ENABLED=true
PROXY_CHECK_TOKEN=replace-with-a-random-token
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
REDIRECTION_HOSTS=proxy.example.com

# TCP/UDP proxy tuning (0 disables timeout)
TCP_PROXY_IDLE_TIMEOUT_MS=0
TCP_PROXY_CONNECT_TIMEOUT_MS=10000
TCP_PROXY_KEEPALIVE_MS=30000
TCP_PROXY_BACKLOG=4096
TCP_PROXY_MAX_CONNECTIONS=0
UDP_PROXY_CLIENT_TIMEOUT_MS=30000

# Health checks
HEALTHCHECK_INTERVAL_SECONDS=5
HEALTHCHECK_CONCURRENCY=10
HEALTHCHECK_TIMEOUT_MS=10000
HEALTHCHECK_CLEANUP_EVERY=100
HEALTHCHECK_SKIP_TCP=true
HEALTHCHECK_SKIP_UDP=false

# Logs
LOG_RETENTION_DAYS=30
LOG_CLEANUP_INTERVAL_HOURS=24

# SMTP Email Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_FROM_NAME=NebulaProxy
SMTP_FROM_EMAIL=

# ACME / Let's Encrypt
ACME_EMAIL=admin@example.com

# Frontend
VITE_API_BASE_URL=/api
VITE_REDIRECT_BASE_URL=https://redirect.paxcia.net

# Redis (for JWT blacklist and enhanced security)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security enhancements
CSRF_ENABLED=true
DNS_REBINDING_PROTECTION=true
TRUSTED_PROXIES=
HSTS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
